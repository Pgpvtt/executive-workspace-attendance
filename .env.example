# ============================================================
# Executive Workspace - Office Attendance System
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.

# ── Supabase (Required) ──────────────────────────────────────
# Find these in your Supabase project: Settings → API

# The URL of your Supabase project
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# The public anon key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Edge Function Secrets (set in Supabase Dashboard) ──
# Go to: Project → Edge Functions → Secrets
# These are NOT set in this file — they live server-side only.
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  (DO NOT put here — server only)
